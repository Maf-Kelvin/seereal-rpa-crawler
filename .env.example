# ── Required ──────────────────────────────────────────────
SEARCH_ADDRESS=서울시 강남구

# ── Target URL ────────────────────────────────────────────
TARGET_URL=https://seereal.lh.or.kr/main.do

# ── Output ────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
PDF_COUNT=3

# ── Worker pool ───────────────────────────────────────────
# Number of parallel tabs for PDF generation.
# 4 is safe for most machines; raise to 6 on high-RAM servers.
MAX_WORKERS=4

# ── Chrome connection ─────────────────────────────────────
# Remote debugging port — script connects to an existing Chrome
# on this port before falling back to launching a new instance.
# Start Chrome manually with: --remote-debugging-port=9222
CHROME_DEBUG_PORT=9222

# ── Chrome path (required by puppeteer-core) ──────────────
# macOS:
#CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows:
CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
# Linux:
# CHROME_PATH=/usr/bin/google-chrome